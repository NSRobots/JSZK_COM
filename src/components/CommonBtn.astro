---
import type { CommonBtn } from "../Interface/site";

// CommonBtn.astro
const { item } = Astro.props as { item: CommonBtn };
---

<div
  style={`--btn-bg: ${item.bgColor}; height: ${item.height}px; width: ${item.width}px; --hover-bg: var(--primary-light-l2)`}
  class=`max-md:w-[110px] max-md:h-[110px]
        p-[14px_20px] rounded-3xl text-base font-medium
         transition-all duration-[250ms] cursor-pointer
         border border-transparent border-[1.5px]
         shadow-none bg-[var(--btn-bg)]
         hover:-translate-y-px hover:shadow-[0_6px_16px_rgba(0,0,0,0.08)]
         hover:bg-[var(--primary-light-l2)]`
>
  <span
    set:html={item.iconSvg}
    class="flex items-center justify-center w-10 h-10
                     [&_svg]:w-full [&_svg]:h-full [&_svg]:block"
  />
  <a
    href={item.href}
    aria-label={item.label}
    style={`color: ${item.itemColor}; `}
    target={item.isRedirect ? "_blank" : "_self"}
    class="flex flex-col items-center justify-center w-full h-full
                   no-underline gap-2.5 box-border rounded-xl"
  >
    <p>{item.label}</p>
  </a>
</div>
