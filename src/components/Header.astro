---
import { commonItems } from "../data/btnDatas";
import DownloadModal from "./Modals/DownloadModal.astro";

// Header.astro - 顶部导航栏（桌面端 + 移动端侧边栏）
function getModalId(label: string): string {
  return `modal-${label.replace(/[^a-zA-Z0-9\u4e00-\u9fa5]/g, "-")}`;
}

const currentPath = Astro.url.pathname.replace(/\/$/, "");

// 过滤当前的路由
const items = Object.values(commonItems).filter((item) => {
  // 保留：空href的Modal按钮（如下载）和所有外部链接
  if (!item.href || item.href.startsWith("http")) {
    return true;
  }

  // 统一去掉末尾斜杠后比较是否为当前路由
  const itemPath = item.href.replace(/\/$/, "");
  return itemPath !== currentPath;
});
const modalItems = items.filter((item) => item.isModal);

// const items = Object.values(commonItems);
// const modalItems = items.filter((item) => item.isModal);
---

<div
  class="sticky top-0 z-50 text-white w-full px-5 flex items-center bg-[var(--primary-dark)]"
>
  <div class="left-0 right-0 px-4 py-4 flex items-center">
    <!-- Logo & title -->
    <div
      class="w-7 h-7 bg-white text-[#4CAF50] rounded flex items-center justify-center font-bold mr-3 shrink-0"
    >
      <a href="/">
        <img src="/ZK.ico" alt="Logo" class="w-full h-full object-contain" />
      </a>
    </div>
    <span class="text-2xl font-bold"><a href="/">键鼠智控 </a></span>
  </div>

  <!-- 移动端菜单遮罩层 -->
  <div
    id="mobileMenuOverlay"
    class="fixed inset-0 bg-black/50 z-40 hidden md:hidden"
  >
  </div>

  <!-- 桌面端顶部导航 -->
  <nav class="ml-auto hidden md:flex items-center space-x-6">
    {
      items.map((item) => {
        const mid = getModalId(item.label);
        return item.isModal ? (
          <button
            aria-label={item.label}
            class="hover:text-gray-200 hover:underline underline-offset-4 decoration-2 transition-all duration-200 px-3"
            data-modal-trigger={mid}
          >
            {item.label}
          </button>
        ) : (
          <a
            href={item.href}
            target={item.isRedirect ? "_blank" : "_self"}
            class="hover:text-gray-200 hover:underline underline-offset-4 decoration-2 transition-all duration-200 px-3"
          >
            {item.label}
          </a>
        );
      })
    }
  </nav>

  <!-- 移动端侧边栏 -->
  <div
    id="mobileSidebar"
    class="fixed top-0 left-[-100%] w-50 h-full shadow-lg bg-[var(--primary)] z-50 transition-all duration-300 md:hidden"
  >
    <div class="p-4 bg-[var(--primary-dark)] border-b border-white/20">
      <div class="flex items-center justify-between">
        <div class="flex items-center">
          <div
            class="w-7 h-7 bg-white text-[#4CAF50] rounded flex items-center justify-center font-bold mr-3"
          >
            <a href="/">
              <img
                src="/ZK.ico"
                alt="Logo"
                class="w-full h-full object-contain"
              />
            </a>
          </div>
          <span class="text-xl font-bold">键鼠智控</span>
        </div>
        <button
          id="closeMobileMenu"
          class="hover:bg-white/10 rounded transition-colors w-6 h-6 border-none rounded-full
           leading-none cursor-pointer text-2xl"
          >&times;
        </button>
      </div>
    </div>
    <div class="p-4">
      <nav class="flex flex-col space-y-4">
        {
          items.map((item) => {
            const mid = getModalId(item.label);
            return item.isModal ? (
              <button
                class="py-3 px-4 hover:bg-white/10 hover:underline rounded transition-colors duration-200 w-full text-left text-white"
                data-modal-trigger={mid}
                onclick="closeMobileMenu()"
              >
                {item.label}
              </button>
            ) : (
              <a
                href={item.href}
                target={item.isRedirect ? "_blank" : "_self"}
                class="py-3 px-4 hover:bg-white/10 hover:underline rounded transition-colors duration-200"
                onclick="closeMobileMenu()"
              >
                {item.label}
              </a>
            );
          })
        }
      </nav>
    </div>
  </div>

  <!-- 移动端菜单按钮 -->
  <button id="mobileMenuButton" class="ml-auto md:hidden p-2">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M4 6h16M4 12h16M4 18h16"></path>
    </svg>
  </button>
</div>

<!-- Modal 弹窗（仅为 isModal 的条目渲染） -->
{
  modalItems.map((item) => {
    const mid = getModalId(item.label);
    return <DownloadModal modalId={mid} />;
  })
}

<script>
  // ===== 移动端菜单逻辑 =====
  const mobileMenuButton = document.getElementById("mobileMenuButton");
  const mobileSidebar = document.getElementById("mobileSidebar");
  const mobileMenuOverlay = document.getElementById("mobileMenuOverlay");
  const closeMobileMenuBtn = document.getElementById("closeMobileMenu");

  // 打开移动端菜单
  function openMobileMenu() {
    if (mobileSidebar) mobileSidebar.style.left = "0";
    if (mobileMenuOverlay) mobileMenuOverlay.style.display = "block";
    document.body.style.overflow = "hidden";
  }

  // 关闭移动端菜单
  function closeMobileMenu() {
    if (mobileSidebar) mobileSidebar.style.left = "-100%";
    if (mobileMenuOverlay) mobileMenuOverlay.style.display = "none";
    document.body.style.overflow = "";
  }

  if (mobileMenuButton) {
    mobileMenuButton.addEventListener("click", openMobileMenu);
  }

  if (closeMobileMenuBtn) {
    closeMobileMenuBtn.addEventListener("click", closeMobileMenu);
  }

  if (mobileMenuOverlay) {
    mobileMenuOverlay.addEventListener("click", closeMobileMenu);
  }

  // ===== Modal 触发器绑定 =====
  document.querySelectorAll("[data-modal-trigger]").forEach((trigger) => {
    trigger.addEventListener("click", () => {
      const modalId = trigger.getAttribute("data-modal-trigger");
      if (modalId) {
        const dialog = document.getElementById(modalId);
        if (dialog instanceof HTMLDialogElement) {
          dialog.showModal();
        }
      }
    });
  });

  // ESC键关闭菜单（但不影响 Modal 自带的 ESC 关闭）
  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      closeMobileMenu();
    }
  });
</script>

<style>
  @reference "tailwindcss";

  #mobileSidebar {
    z-index: 40;
  }

  body.menu-open {
    @apply overflow-hidden;
  }

  #mobileMenuOverlay {
    @apply fixed inset-0;
    background-color: rgba(0, 0, 0, 0.5);
    display: none;
  }
</style>
