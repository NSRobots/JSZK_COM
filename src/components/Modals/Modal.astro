---
export interface Props {
  /** 唯一标识，用于 trigger 关联 */
  id: string;
  /** 弹窗宽度（PC端），默认 30vw */
  width?: string;
  /** 弹窗高度（PC端），默认 30vh */
  height?: string;
  /** 是否显示右上角关闭按钮，默认 true */
  showCloseButton?: boolean;
}

const {
  id,
  width = "460px",
  height = "380px",
  showCloseButton = true,
} = Astro.props;
---

<dialog
  id={id}
  data-modal
  style={`width: ${width}; height: ${height}; max-width: 90vw; max-height: 85vh;`}
  class="modal-dialog"
>
  <div class="modal-inner">
    {
      showCloseButton && (
        <button
          type="button"
          class="modal-close-btn"
          data-close={id}
          aria-label="关闭弹窗"
        >
          &times;
        </button>
      )
    }
    <div class="modal-body">
      <slot />
    </div>
  </div>
</dialog>

<style>
  @reference "tailwindcss";

  /* ===== 弹窗主体 ===== */
  .modal-dialog {
    @apply m-auto border-none rounded-2xl p-0;
    margin: auto;
    background: rgba(255, 255, 255);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
    display: flex;
    flex-direction: column;
    opacity: 0;
    transform: scale(0.95) translateY(10px);
    transition:
      opacity 0.25s ease-out,
      transform 0.25s ease-out,
      overlay 0.25s ease-out allow-discrete,
      display 0.25s ease-out allow-discrete;
  }

  /* 打开状态 */
  .modal-dialog[open] {
    @apply opacity-100 scale-100 translate-y-0;
  }

  /* 打开动画的起始状态（现代浏览器） */
  @starting-style {
    .modal-dialog[open] {
      opacity: 0;
      transform: scale(0.95) translateY(10px);
    }
  }

  /* ===== 遮罩层 ===== */
  .modal-dialog::backdrop {
    background: rgba(0, 0, 0, 0.4);
    /* backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px); */
    opacity: 0;
  }

  .modal-dialog[open]::backdrop {
    opacity: 1;
  }

  /* ===== 关闭按钮 ===== */
  .modal-close-btn {
    @apply absolute top-3 right-3 z-10
           w-8 h-8 border-none rounded-full
           text-xl leading-none text-gray-500 cursor-pointer
           flex items-center justify-center;
    background: rgba(0, 0, 0, 0.06);
    transition:
      background 0.2s,
      color 0.2s;
  }

  .modal-close-btn:hover {
    @apply text-gray-700;
    background: rgba(0, 0, 0, 0.12);
  }

  /* ===== 内容容器 ===== */
  .modal-inner {
    @apply relative;
    height: auto;
    max-height: 85vh;

    &::-webkit-scrollbar {
      display: none;
    }
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .modal-body {
    @apply p-6 overflow-y-auto;
    overflow-y: hidden;
    max-height: min(calc(85vh - 3rem), 350px);
  }

  /* 移动端适配 */
  @media (max-width: 768px) {
    .modal-dialog {
      width: 90vw !important;
      max-height: 80vh;
      @apply rounded-xl;
    }

    .modal-body {
      @apply p-5;
      max-height: min(calc(85vh - 3rem), 350px);
    }
  }
</style>

<script>
  // 统一处理所有 [data-close] 关闭按钮
  document.querySelectorAll("[data-close]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const dialogId = btn.getAttribute("data-close");
      if (dialogId) {
        const dialog = document.getElementById(dialogId);
        if (dialog instanceof HTMLDialogElement) {
          dialog.close();
        }
      }
    });
  });

  // 点击遮罩层关闭（点击 dialog 背景区域）
  document.querySelectorAll("[data-modal]").forEach((dialog) => {
    dialog.addEventListener("click", (e) => {
      if (e.target === dialog && dialog instanceof HTMLDialogElement) {
        dialog.close();
      }
    });
  });
</script>
