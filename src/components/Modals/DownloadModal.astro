---
import Modal from "./Modal.astro";
import CommonBtn from "../Buttons/CommonBtn.astro";
import { dlChannels } from "../../data/btnDatas";

export interface Props {
  modalId?: string;
}

const { modalId = "download-modal" } = Astro.props;
---

<Modal id={modalId} showCloseButton={true}>
  <div class="flex flex-col items-center gap-4">
    <h3 class="text-2xl font-semibold text-gray-800 m-0">请选择下载渠道</h3>
    <div class="flex flex-wrap justify-center gap-4 mt-4 mb-4">
      {dlChannels.map((channel) => <CommonBtn item={channel} />)}
    </div>
  </div>
</Modal>
