---
import "../styles/global.css";

// Btn2Idx.astro
// 接收一个 buttons 数组，每个按钮格式：
// { href: string, label: string, variant: 'download' | 'learn' | 'other', iconSvg: string }
const { buttons } = Astro.props as { buttons: ButtonItem[] };

export interface ButtonItem {
  href: string;
  label: string;
  variant?: string; // 类型
  iconSvg: string;
  logoColor: string; // 图标颜色
}
---

<div class="common-buttons animate-fade-in-up">
  {
    buttons.map((btn: any) => (
      <a
        href={btn.href}
        class={`btn ${btn.variant || ""}`}
        aria-label={btn.label}
        style={`color: ${btn.logoColor}`}
      >
        <span class="btn-icon" set:html={btn.iconSvg} />
        <p>{btn.label}</p>
      </a>
    ))
  }
</div>

<style>
  /* 所有按钮相关样式都挪到这里，Astro 会自动 scoped */
  .common-buttons {
    display: flex;
    flex-direction: row;
    justify-content: center;
    gap: 45px;
    margin: 0 auto;
  }

  .btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 140px;
    height: 140px;
    padding: 14px 20px;
    border-radius: 12px;
    font-size: 16px;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.25s ease;
    cursor: pointer;
    border: 1.5px solid transparent;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
    background: var(--white, #ffffff);
  }

  .btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.08);
  }

  .btn p {
    color: var(--black-text);
    margin: 0;
  }

  .btn-icon {
    width: 50px;
    height: 50px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .btn-icon :global(svg) {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* ---------- 手机端适配（宽度 ≤ 768px） ---------- */
  @media (max-width: 768px) {
    .common-buttons {
      flex-direction: column; /* 竖向排列 */
      justify-content: center;
      align-items: center;
      gap: 30px; /* 间距适当缩小 */
      max-width: 100%;
      padding: 0 16px;
    }

    .btn {
      width: 130px; /* 手机端按钮稍小一点也很舒服 */
      height: 130px;
    }
  }
</style>
