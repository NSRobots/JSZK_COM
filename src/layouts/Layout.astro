---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>JSZK- 轻松一键，键鼠智控</title>
    <style>
      /* ========== 上方淡蓝色区域 ========== */
      .hero {
        background: var(--primary);
        text-align: center;
        /* 底部留出足够空间给弧线 */
        padding: 8% 24px 40px;
        position: relative;
        /* margin-bottom: 160px; */
      }

      /* 语言标识 */
      /* .lang-tag {
        display: inline-block;
        font-size: 13px;
        color: var(--text-secondary);
         border: 1px solid #b3d9ff; 
        border-radius: 20px;
        padding: 4px 16px;
        margin-bottom: 36px;
        letter-spacing: 0.5px;
        background: rgba(255, 255, 255, 0.6);
        backdrop-filter: blur(4px);
      } */

      /* Logo */
      .logo {
        display: flex;
        align-items: center;
        justify-content: center;
        /* width: 72px;
        height: 172px; */
        gap: 16px;
        margin: 0 auto 20px;
      }
      .logo img {
        width: 68px;
        height: 68px;
        object-fit: contain;
      }

      /* 标题 */
      .logo .title {
        font-size: 48px;
        font-weight: 600;
        color: var(--white-text);
        margin: 0;
        padding: 0 0 8px 0;
        letter-spacing: 2px;
      }

      .description {
        font-size: 32px;
        color: var(--white-text);
        margin-bottom: 40px;
        line-height: 1.8;
      }

      /* ========== 弧形分隔 ========== */
      .hero::after {
        content: "";
        position: absolute;
        /* 弧线高度 */
        bottom: -120px;
        left: 0;
        width: 100%;
        height: 120px;
        background: var(--primary);
        /* 弧线弧度 */
        border-radius: 0 0 50% 50% / 0 0 50% 50%;
      }

      /* 响应式 */
      @media (max-width: 400px) {
        .hero {
          padding: 40px 20px 70px;
          margin-bottom: 50px;
        }
        .hero::after {
          bottom: -40px;
          height: 50px;
        }
        .common-buttons {
          max-width: 100%;
          padding: 0 8px;
        }
      }
    </style>
  </head>
  <body>
    <!-- Content淡蓝色背景区域 -->
    <div class="hero">
      <!-- <div class="lang-tag">简体中文</div> -->

      <div class="logo animate-fade-in-up">
        <img src="/ZK.ico" alt="键鼠智控" />
        <h1 class="title">JSZK</h1>
      </div>

      <div class="description animate-fade-in-up">
        <p>键鼠智控<br />轻松一键，告别重复操作！</p>
      </div>

      <Button {buttons} />
    </div>

    <!-- about底部白色区域 -->
    <div class="footer">
      <nav class="footer-links">
        <a href="#">联系我们</a>
        <a href="#">服务条款</a>
        <a href="#">隐私政策</a>
      </nav>

      <p class="footer-copyright">
        Copyright © 2023-2026 CZZM. All Rights Reserved.
      </p>
    </div>
  </body>
</html>
