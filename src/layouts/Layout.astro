---
// layout.astro
import Button from "../components/Btn2Idx.astro";
import "../styles/global.css";

const buttons = [
  {
    href: "https://gitee.com/czhaozm/JSZK/releases/download/v4.1.0.0/JSZK.zip",
    label: "下载",
    variant: "download",
    logoColor: "#e60013",
    iconSvg: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"> 
      <path d="M12 3 L12 16" /> 
      <path d="M8 13 L12 17 L16 13" /> 
      <path d="M4 21 L20 21" />
    </svg>`,
  },
  {
    href: "https://www.bilibili.com/video/BV1Vqjpz5ETy",
    label: "教程",
    variant: "vedio",
    logoColor: "#f39800",
    iconSvg: `<p style="font-size: 25px; font-weight: bold;">BiliBili</p>`,
  },
  {
    href: "./about/",
    label: "海报",
    variant: "other",
    logoColor: "#8ec31f",
    iconSvg: `<svg viewBox="0 0 24 24" fill="currentColor">
      <path d="M8.691 2.188C3.891 2.188 0 5.476 0 9.53c0 2.212 1.17 4.203 3.002 5.55a.59.59 0 0 1 .213.665l-.39 1.48c-.019.07-.048.141-.048.213 0 .163.13.295.29.295a.326.326 0 0 0 .167-.054l1.903-1.114a.864.864 0 0 1 .717-.098 10.16 10.16 0 0 0 2.837.403c.276 0 .543-.027.811-.05-.857-2.578.157-4.972 1.932-6.446 1.703-1.415 3.882-1.98 5.853-1.838-.576-3.583-4.196-6.348-8.596-6.348zM5.785 5.991c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 0 1-1.162 1.178A1.17 1.17 0 0 1 4.623 7.17c0-.651.52-1.18 1.162-1.18zm5.813 0c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 0 1-1.162 1.178 1.17 1.17 0 0 1-1.162-1.178c0-.651.52-1.18 1.162-1.18zm5.34 2.867c-1.797-.052-3.746.512-5.28 1.786-1.72 1.428-2.687 3.72-1.78 6.22.942 2.453 3.666 4.229 6.884 4.229.826 0 1.622-.12 2.361-.336a.722.722 0 0 1 .598.082l1.584.926a.272.272 0 0 0 .14.047c.134 0 .24-.111.24-.247 0-.06-.023-.12-.038-.177l-.327-1.233a.49.49 0 0 1 .178-.554C23.028 18.48 24 16.82 24 14.98c0-3.21-2.931-5.952-7.062-6.122zM16.382 12.9c.534 0 .967.44.967.982a.975.975 0 0 1-.967.983.975.975 0 0 1-.967-.983c0-.542.433-.982.967-.982zm4.836 0c.534 0 .967.44.967.982a.975.975 0 0 1-.967.983.975.975 0 0 1-.967-.983c0-.542.433-.982.967-.982z"/>
