---
import Button from "../components/CubeBtn.astro";
import type { CubeBtn } from "../Interface/site";
import { dlChannels } from "../data/btnDatas";
---

<style>
  /* 弧形分隔复用 */
  .banner-body {
    position: relative;
    background-color: var(--primary);
  }

  .banner-body::after {
    content: "";
    position: absolute;
    bottom: -59px;
    left: 0;
    width: 100%;
    height: 60px;
    background: var(--primary);
    clip-path: ellipse(130% 100% at 60% 0%);
    border-radius: 0 0 50% 50% / 0 0 60% 60%;
  }

  @media (max-width: 768px) {
    .banner-body::after {
      bottom: -35px;
    }
  }
</style>

<div
  style="padding-top: 140px; padding-left: 24px; padding-right: 24px;"
  class="banner-body relative text-center pb-10"
>
  <!-- 返回首页 -->
  <a
    href="/"
    class="animate-fade-in-up absolute top-10 left-10 text-lg text-[var(--gray)] px-4 hover:text-[var(--white)] transition-colors duration-300"
    aria-label="返回首页"
  >
    &lt;--
  </a>
  <!-- 语言标签 -->
  <p
    class="animate-fade-in-up absolute top-10 right-10 text-lg text-[var(--gray)] px-4 pointer-events-none"
  >
    JSZK
  </p>

  <!-- logo & title -->
  <div
    class="animate-fade-in-up flex items-center justify-center gap-4 h-[68px]"
  >
    <img
      src="/ZK.ico"
      alt="键鼠智控"
      class="w-[56px] h-[56px] object-contain"
    />
    <h1
      class="text-[48px] font-semibold text-[var(--white)] tracking-wider pd-1"
    >
      键鼠智控
    </h1>
  </div>

  <!-- typing animate -->
  <div
    id="contact-lines"
    class="animate-fade-in-up h-[140px] w-full text-3xl text-[var(--white)] mt-10 leading-[1.8] text-[18px] md:text-[28px]"
  >
  </div>

  <!-- button box -->
  <div
    class="animate-fade-in-up flex flex-row flex-wrap justify-center items-center gap-[45px] max-w-full px-4 ax-md:gap-[70px] max-md:px-4"
  >
    {dlChannels.map((btn: CubeBtn) => <Button item={btn} />)}
  </div>
</div>

<script lang="ts">
  const typingText = `请选择下载方式`;

  const speed = 50; // 打字速度（毫秒/字）
  const firstDelayTime = 320;
  const betweenLinesDelay = 400; // 行与行之间的延迟

  async function delay(ms) {
    return await new Promise((resolve) => setTimeout(resolve, ms));
  }

  async function typeText(element, text) {
    element.textContent = "";
    for (let i = 0; i < text.length; i++) {
      // 逐字添加
      if (element.id === "line1" && i === 2) {
        // 第一个字后延迟
        await delay(firstDelayTime);
      }
      element.textContent += text.charAt(i);
      await delay(speed);
    }
  }

  async function typeText(element, text) {
    element.textContent = "";
    for (let i = 0; i < text.length; i++) {
      // 逐字添加
      if (element.id === "line1" && i === 2) {
        // 第一个字后延迟
        await delay(firstDelayTime);
      }
      element.textContent += text.charAt(i);
      await delay(speed);
    }
  }

  async function startTyping() {
    // 1. 按 \n 分割文本
    const linesArray = typingText.split("\n");
    const container = document.getElementById("contact-lines");
    if (!container) return;

    // 2. 清空容器并动态创建 p 标签
    container.innerHTML = "";
    const typedElements = [];

    linesArray.forEach((lineText) => {
      const p = document.createElement("p");
      p.className = "typing-line";
      container.appendChild(p);
      typedElements.push(p);
    });

    // 3. 逐行动画
    for (let i = 0; i < typedElements.length; i++) {
      const el = typedElements[i];
      el.classList.add("typing-cursor"); // 显示光标
      await typeText(el, linesArray[i], i);
      el.classList.remove("typing-cursor"); // 移除光标

      if (i < typedElements.length - 1) {
        await delay(betweenLinesDelay);
      }
    }
  }

  // 页面加载完成后启动动画
  document.addEventListener("DOMContentLoaded", startTyping);
</script>
