---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import { getBannerHeightCSS } from "../data/pageDataMap";

const data = {
  title: "404",
  buttons: null,
  height: { base: "480px", md: "540px", lg: "530px" },
  typingSections: [
    {
      lines: ["哎呀，页面走丢了......", "未能找到您请求的路径"],
      typingClass: "text-[18px] md:text-[22px] pb-6 md:pb-10",
      typingSpeed: 35,
    },
    {
      lines: ["请检查网址是否正确,", "或点击左上角箭头返回首页"],
      typingClass: "text-[26px] md:text-[28px] pt-4 md:pt-6",
      typingSpeed: 35,
    },
  ],
  showBack: true,
  showJSZK: true,
  showTitleLogo: false,
  logoLinked: false,
  boxStyle: "padding-top: 60px;",
};
const bannerHeight = getBannerHeightCSS(data.height);
---

<Layout>
  <div
    id="banner"
    slot="content"
    style={`min-height: var(--banner-h, ${bannerHeight.base}); padding-left: 24px; padding-right: 24px; ${data.boxStyle}`}
    class="banner-body pb-10"
  >
    <!-- 返回首页 -->
    {
      data.showBack && (
        <a
          href="/"
          class="animate-fade-in-up absolute top-10 left-10 text-lg text-[var(--gray)] px-4 hover:text-[var(--white)] transition-colors duration-300"
          aria-label="返回首页"
        >
          <img
            src="/logos/pre-white.png"
            class="w-[16px] h-[16px] object-contain"
            alt="返回首页"
          />
        </a>
      )
    }

    <!-- 语言标签 -->
    {
      data.showJSZK && (
        <p class="animate-fade-in-up absolute top-10 right-10 text-lg text-[var(--gray)] px-4 pointer-events-none">
          JSZK
        </p>
      )
    }

    <!-- logo & title -->
    <div
      class="animate-fade-in-up flex items-center justify-center gap-4 h-[68px]"
    >
      <h1
        class="text-[48px] font-semibold text-[var(--white)] tracking-wider pd-1"
      >
        {data.title}
      </h1>
    </div>

    <!-- typing area -->
    <div
      id="typing-container"
      class="animate-fade-in-up text-center min-h-[120px] w-full text-[var(--white)] mt-10 mb-10 leading-[1.8]"
      data-sections={JSON.stringify(data.typingSections)}
      data-first-delay={320}
      data-between-lines-delay={100}
      data-between-sections-delay={10}
    >
    </div>

    <!-- 响应式高度 -->
    {
      bannerHeight.mediaQueries && (
        <style set:html={bannerHeight.mediaQueries} />
      )
    }
  </div>

  <Footer slot="footer" />
</Layout>

<script>
  async function delay(ms: number) {
    return await new Promise((resolve) => setTimeout(resolve, ms));
  }

  async function typeText(
    element: HTMLElement,
    text: string,
    lineIndex: number,
    speed: number,
    firstDelayTime: number,
  ) {
    for (let i = 0; i < text.length; i++) {
      if (lineIndex === 0 && i === 2) {
        await delay(firstDelayTime);
      }
      element.textContent += text.charAt(i);
      await delay(speed);
    }
  }

  async function startTyping() {
    const container = document.getElementById("typing-container");
    if (!container) return;

    const sections: Array<{
      lines: string[];
      typingClass: string;
      typingSpeed?: number;
    }> = JSON.parse(container.dataset.sections || "[]");

    const firstDelayTime = parseInt(container.dataset.firstDelay || "320", 10);
    const betweenLinesDelay = parseInt(
      container.dataset.betweenLinesDelay || "400",
      10,
    );
    const betweenSectionsDelay = parseInt(
      container.dataset.betweenSectionsDelay || "600",
      10,
    );

    container.innerHTML = "";

    for (let sectionIndex = 0; sectionIndex < sections.length; sectionIndex++) {
      const section = sections[sectionIndex];
      const speed = section.typingSpeed ?? 50;

      const sectionContainer = document.createElement("div");
      sectionContainer.className = section.typingClass;
      container.appendChild(sectionContainer);

      const typedElements: HTMLElement[] = [];
      section.lines.forEach((lineText) => {
        const p = document.createElement("p");
        p.className = "typing-line";
        sectionContainer.appendChild(p);
        typedElements.push(p);
      });

      for (let i = 0; i < typedElements.length; i++) {
        const el = typedElements[i];
        el.classList.add("typing-cursor");
        await typeText(el, section.lines[i], i, speed, firstDelayTime);
        el.classList.remove("typing-cursor");

        if (i < typedElements.length - 1) {
          await delay(betweenLinesDelay);
        }
      }

      if (sectionIndex < sections.length - 1) {
        await delay(betweenSectionsDelay);
      }
    }
  }

  document.addEventListener("DOMContentLoaded", startTyping);
</script>

<style>
  .banner-body {
    position: relative;
    background-color: var(--primary);
  }

  .banner-body::after {
    content: "";
    position: absolute;
    bottom: -59px;
    left: 0;
    width: 100%;
    height: 60px;
    background: var(--primary);
    clip-path: ellipse(130% 100% at 60% 0%);
    border-radius: 0 0 50% 50% / 0 0 60% 60%;
  }

  @media (max-width: 768px) {
    .banner-body::after {
      bottom: -35px;
    }
  }
</style>
